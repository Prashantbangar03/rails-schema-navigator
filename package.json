{
  "name": "rails-schema-navigator",
  "displayName": "Rails Schema Navigator",
  "description": "Navigate Rails db/structure.sql and db/schema.rb visually — tables, columns, foreign keys, PostgreSQL enums, views, join tables, and ActiveRecord model links.",
  "version": "1.0.0",
  "publisher": "prashantbangar03",
  "author": {
    "name": "Prashant Bangar"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "galleryBanner": {
    "color": "#0a0e16",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Prashantbangar03/rails-schema-navigator.git"
  },
  "bugs": {
    "url": "https://github.com/Prashantbangar03/rails-schema-navigator/issues"
  },
  "homepage": "https://github.com/Prashantbangar03/rails-schema-navigator#readme",
  "qna": "https://github.com/Prashantbangar03/rails-schema-navigator/issues",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Requires local db/structure.sql or db/schema.rb files in the workspace."
    }
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "rails",
    "ruby",
    "ruby on rails",
    "rails schema",
    "schema navigator",
    "schema.rb",
    "structure.sql",
    "postgresql",
    "postgres",
    "database",
    "database schema",
    "db schema",
    "active record",
    "activerecord",
    "foreign keys",
    "foreign key",
    "migrations",
    "join table",
    "many-to-many",
    "enum",
    "postgresql enum",
    "schema explorer",
    "erd",
    "table viewer",
    "cursor",
    "vscode"
  ],
  "activationEvents": [
    "onCommand:schemaExplorer.open",
    "onCommand:schemaExplorer.openFromModel",
    "onCommand:schemaExplorer.switchProject",
    "onCommand:schemaExplorer.refresh",
    "onWebviewPanel:schemaExplorerPanel",
    "workspaceContains:**/db/structure.sql",
    "workspaceContains:**/db/schema.rb"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "schemaExplorer.open",
        "title": "Rails Schema Navigator: Open",
        "category": "Rails Schema Navigator",
        "icon": "$(database)"
      },
      {
        "command": "schemaExplorer.openFromModel",
        "title": "Rails Schema Navigator: Open from Model",
        "category": "Rails Schema Navigator",
        "icon": "$(database)"
      },
      {
        "command": "schemaExplorer.findTable",
        "title": "Rails Schema Navigator: Find Table",
        "category": "Rails Schema Navigator",
        "icon": "$(search)"
      },
      {
        "command": "schemaExplorer.switchProject",
        "title": "Rails Schema Navigator: Switch Project",
        "category": "Rails Schema Navigator",
        "icon": "$(repo)"
      },
      {
        "command": "schemaExplorer.refresh",
        "title": "Rails Schema Navigator: Refresh",
        "category": "Rails Schema Navigator",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Rails Schema Navigator",
      "properties": {
        "schemaExplorer.followEditor": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, the explorer switches schema projects as you change the active editor. When disabled, the active project stays pinned."
        },
        "schemaExplorer.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the active schema project in the status bar."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "schemaExplorer.open",
          "when": "resourceFilename == structure.sql || resourceFilename == schema.rb",
          "group": "navigation"
        },
        {
          "command": "schemaExplorer.openFromModel",
          "when": "resourcePath =~ /app\\/models\\/.+\\.rb$/ && resourcePath !~ /concerns/",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "schemaExplorer.open",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "!terminalFocus"
      },
      {
        "command": "schemaExplorer.findTable",
        "key": "ctrl+shift+j",
        "mac": "ctrl+shift+j",
        "when": "!terminalFocus"
      },
      {
        "command": "schemaExplorer.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "activeWebviewPanelId == schemaExplorerPanel"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && tsc -p test && node --require ./out-test/helpers/register-vscode-mock.js --test --test-concurrency=1 out-test/**/*.test.js",
    "test:coverage": "npm run compile && tsc -p test && c8 --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 --include 'out/**/*.js' --exclude 'out-test/**' node --require ./out-test/helpers/register-vscode-mock.js --test --test-concurrency=1 out-test/**/*.test.js",
    "test:compile": "tsc -p test",
    "package": "vsce package --no-dependencies --no-rewrite-relative-links",
    "publish:marketplace": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "c8": "^10.1.3",
    "typescript": "^5.3.0"
  }
}
